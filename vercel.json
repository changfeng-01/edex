{
  "installCommand": "python -m pip install -r requirements-vercel.txt",
  "functions": {
    "api/index.py": {
      "maxDuration": 60,
      "memory": 1024,
      "excludeFiles": "{tests/**,docs/**,papers/**,outputs/**,output/**,tmp/**,.pytest_cache/**,.ruff_cache/**,.codegraph/**,frontend/**,node_modules/**,720out1/**,benchmarks/**,scripts/**,*.zip,*.docx,*.pdf}"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.py"
    }
  ]
}
